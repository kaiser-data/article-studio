# Local backups exported from the app
article-studio-backup.json

# OS noise
.DS_Store

# User-uploaded images (kept out of version control by default).
# Remove these two lines if you want images committed too.
articles/images/*
!articles/images/.gitkeep

# Personal content stays local — public repo is code only.
# Your article drafts (keep only the welcome sample as documentation):
articles/*.md
!articles/welcome-linkedin-post.md
# Your people directory (real contacts), hashtag sets and agent task notes:
articles/people.json
articles/tagsets.json
articles/.codex-tasks/
articles/.claude-tasks/

# graphify knowledge-graph output (generated tooling artifacts, local only)
graphify-out/
